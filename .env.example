# ===================================
# VOZSEGURA — VARIABLES DE ENTORNO
# ===================================
# Copia este archivo como .env y llena los valores reales
# NUNCA subas .env a GitHub

# ── SERVIDOR ──
PORT=3000
NODE_ENV=development

# ── BASE DE DATOS MySQL ──
# Opción A: Variables separadas (recomendado para Render)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_contraseña_aquí
DB_NAME=vozsegura
DB_SSL=false

# ── AUTENTICACIÓN JWT ──
# Genera un secreto seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio_en_produccion

# ── OPENAI API ──
# Obtén tu clave en: https://console.openai.com
OPENAI_API_KEY= tu_clave_de_api_aqui


# ── FRONTEND (CORS) ──
# En producción pon la URL de tu app en Render
FRONTEND_URL=http://localhost:3000
